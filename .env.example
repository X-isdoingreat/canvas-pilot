# Canvas Pilot env config.
#
# CC: do NOT read these comments back to the user. CC fills in the values
# itself based on the user's answers (Canvas URL). See CLAUDE.md "Helping
# the student configure" for the conversation flow.
#
# Cookie auth via headless Chromium — canvas-setup drives the one-time
# browser login on first run. CANVAS_BASE / CANVAS_WEB_BASE derived from
# the user's Canvas URL.

CANVAS_AUTH=cookie
CANVAS_BASE=
CANVAS_WEB_BASE=
# Password persistence is opt-in. Browser session cookies remain local either way.
CANVAS_REMEMBER_CREDENTIALS=false
